<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <title>{{ frontmatter.title }}</title>

    <meta name="google-site-verification" content="46a7V_NIglu9MvjEX4267RGvXUGqYaic6LPWM6eQ824" />

    {{> _common-html-header }}
  </head>
  <body>
    <div class="board_view">
      {{> _page-header }}
      <main class="dm-main-content is-fixed">
        <div class="dm-tab-filter-wrapper">
          <div class="dm-tab-filter">
            <ul class="dm-filters d-block d-md-none">
              <li class="placeholder">
                <a data-type="all" href="#0">All</a> <!-- selected option on mobile -->
              </li>
              <li class="filter"><a class="selected" href="#0" data-filter="*">All</a></li>
              <li class="filter"><a href="#1" data-filter=".me .card">Me</a></li>
              <li class="filter"><a href="#2" data-filter=".experience .card">Experience</a></li>
              <li class="filter"><a href="#3" data-filter=".education .card">Education</a></li>
              <li class="filter"><a href="#6" data-filter=".essay .card">Essays</a></li>
              <li class="filter"><a href="#7" data-filter=".project .card">Projects</a></li>
              <li class="filter"><a href="#4" data-filter=".research .card">Research</a></li>
              <li class="filter"><a href="#5" data-filter=".article .card">Articles</a></li>
              <li class="filter"><a href="#9" data-filter=".bonsai .card">Bonsai</a></li>
              <li class="filter"><a href="#8" data-filter=".quote .card">Quotes</a></li>
            </ul> <!-- dm-filters -->
          </div> <!-- dm-tab-filter -->

          <div class="container-fluid float-left">
            <div id="dm-board-header" class="row d-none d-md-flex">
              <div class="plan col-md-{{ frontmatter.plan_cols }}"><span>PLAN</span></div>
              <div class="in_progress col-md-{{ frontmatter.in_progress_cols }}"><span>IN PROGRESS</span></div>
              <div class="done col-md-{{ frontmatter.done_cols }}"><span>DONE</span></div>
            </div>
            <div id="dm-board-header-descs" class="row d-none d-md-flex">
              <div class="col-md-{{ frontmatter.plan_cols }}">Intentions · Ideas · Next Steps</div>
              <div class="col-md-{{ frontmatter.in_progress_cols }}">Focus · Current Efforts · Momentum</div>
              <div class="col-md-{{ frontmatter.done_cols }}">Outcomes · Experience · Insights</div>
            </div>
          </div>
        </div> <!-- dm-tab-filter-wrapper -->

        <div class="container-fluid dm-board">
          <div class="row splitter">
            <div class="col-md-12 text-center">Featured</div>
          </div>
          <div class="row featured">
            <div class="plan iso col-md-12">
              <div id="new_essay">
                <span class="transition">
                  <i class="fa fa-heartbeat" aria-hidden="true"></i>
                  <a href='/ai-multi-turn-feature-generation' style='text-decoration: underline;'>
                    AI Multi-Turn Feature Generation
                  </a>
                </span>
                |
                <a href="/essays" style="text-decoration: underline; padding: 1px 2px;">More essays</a>
              </div>
            </div>
          </div>
          <div class="row splitter">
            <h1 class="col-md-12 text-center">Me</h1>
          </div>
          <div class="row me">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Me)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Me)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Me)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Experience</h1>
          </div>
          <div class="row experience">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Experience)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Experience)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Experience)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Education</h1>
          </div>
          <div class="row education">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Education)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Education)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Education)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Essays &amp; Field Notes</h1>
          </div>
          <div class="row essay">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Essay)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Essay)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Essay)}}
                {{> _task }}
              {{/each}}
              <div class="card task" style="background-color: #FFEA99; color: {{getTextColor '#FFEA99'}}">
                <a href="/essays" title="Archive of essays" style="color: {{getTextColor '#FFEA99'}}">
                  <h2 class="card-header ellipsis">
                    Archive of essays
                  </h2>
                  <h3 class="card-body card-text">List of all my essays written to help the companies I have worked for, to consolidate knowledge, share my opinions or disseminate scientific information in a consumable format.</h3>
                </a>
                <ul class="list-group list-group-flush">
                  <li class="list-group-item">
                      <span class="badge float-right" style="background-color: #FFEA99; color: {{getTextColor '#FFEA99'}}">2013 - Now</span>
                  </li>
                </ul>
              </div>
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Projects/Products</dih1v>
          </div>
          <div class="row project">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Project)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Project)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Project)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Research</h1>
          </div>
          <div class="row research">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Research)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Research)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Research)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Articles</h1>
          </div>
          <div class="row article">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Article)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Article)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Article)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Bonsai</h1>
          </div>
          <div class="row bonsai">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Bonsai)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Bonsai)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Bonsai)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          <div class="row splitter">
            <h1 class="col-md-12 text-center">Quotes</h1>
          </div>
          <div class="row quote">
            <div class="plan iso col-md-{{ frontmatter.plan_cols }}">
              {{#each (getPlannedTasks laneContent.Quote)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="in_progress iso col-md-{{ frontmatter.in_progress_cols }}">
              {{#each (getInProgressTasks laneContent.Quote)}}
                {{> _task }}
              {{/each}}
            </div>
            <div class="done iso col-md-{{ frontmatter.done_cols }}">
              {{#each (getDoneTasks laneContent.Quote)}}
                {{> _task }}
              {{/each}}
            </div>
          </div>

          {{!-- <div class="dm-fail-message">No results found</div> --}}
        </div> <!-- container-fluid dm-boar -->

